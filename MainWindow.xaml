<Window x:Class="SoundVibe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SoundVibe" Height="750" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="app_icon.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFD13B8A"/>
        <SolidColorBrush x:Key="ThemeAccentLightBrush" Color="#FF4A90E2"/>
        <SolidColorBrush x:Key="ThemeGlassBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeDarkBgBrush" Color="#40000000"/>

        <LinearGradientBrush x:Key="ThemeSliderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF4A90E2" Offset="0"/>
            <GradientStop Color="#FFD13B8A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ThemeVerticalSliderGradient" StartPoint="0,1" EndPoint="0,0">
            <GradientStop Color="#FF4A90E2" Offset="0"/>
            <GradientStop Color="#FFD13B8A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ThemeMiniGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4A90E2" Offset="0"/>
            <GradientStop Color="#FFD13B8A" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0C4DE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bgBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="bgBorder" Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#90A4AE"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <Border x:Name="indicator" Width="4" HorizontalAlignment="Left"
                                        Background="{DynamicResource ThemeAccentBrush}" CornerRadius="2" Opacity="0" Margin="0,10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" Color="Black" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="SearchBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="PlaceholderText" Text="Search your music..."
                                           Foreground="#607D8B" Margin="15,0,0,0"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumSliderStyle" TargetType="Slider">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="15">
                            <Border Height="3" Background="#30000000" CornerRadius="1.5"
                                    BorderBrush="#15FFFFFF" BorderThickness="1" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Height="15">
                                                    <Border Height="3" CornerRadius="1.5" Background="{DynamicResource ThemeSliderGradient}" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Height="15"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12" Fill="#FFFFFF" Cursor="Hand">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="5" Color="Black" Opacity="0.5" ShadowDepth="1"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalEQSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Height" Value="200"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Margin" Value="15,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid HorizontalAlignment="Center" Width="15">
                            <Border Width="3" Background="#30000000" CornerRadius="1.5"
                                    BorderBrush="#15FFFFFF" BorderThickness="1"
                                    HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Width="15">
                                                    <Border Width="3" CornerRadius="1.5" HorizontalAlignment="Center" Background="{DynamicResource ThemeVerticalSliderGradient}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Width="15"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12" Fill="#FFFFFF" Cursor="Hand">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="5" Color="Black" Opacity="0.5" ShadowDepth="1"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="15,0,30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18"/>
                            <ToggleButton x:Name="toggleButton" BorderBrush="{x:Null}" BorderThickness="0"
                                          Background="Transparent"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Border Background="Transparent"/>
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#90A4AE"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentPresenter" IsHitTestVisible="False"
                                              Margin="{TemplateBinding Padding}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              TextElement.Foreground="#B0C4DE"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" PopupAnimation="Fade">
                                <Border x:Name="dropDownBorder" Background="{DynamicResource ThemeDarkBgBrush}"
                                        BorderBrush="#30FFFFFF" BorderThickness="1"
                                        Margin="0,5,0,0" CornerRadius="10"
                                        MinWidth="{Binding ActualWidth, ElementName=border}">
                                    <ScrollViewer MaxHeight="250">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#B0C4DE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="20" BorderThickness="1" BorderBrush="#40FFFFFF"
        ClipToBounds="True" MouseLeftButtonDown="Window_MouseDown">
        <Grid>
            <Image x:Name="BgAmbientGlow" Stretch="UniformToFill" Opacity="0.3">
                <Image.Effect>
                    <BlurEffect Radius="120"/>
                </Image.Effect>
            </Image>

            <Rectangle x:Name="BgColorRect" Stretch="Fill" Opacity="0.6"/>

            <Border x:Name="BgGlassOverlay" BorderBrush="{DynamicResource ThemeWindowBorderBrush}"
                    BorderThickness="1" CornerRadius="20"
                    Background="{DynamicResource ThemeWindowBg}"/>

            <Grid>
                <Grid x:Name="MainUI" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource ThemeDarkBgBrush}"
                            BorderBrush="#15FFFFFF" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="90"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="130"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="30,0,0,0">
                                <TextBlock Text="ılı" Foreground="{DynamicResource ThemeAccentBrush}" FontSize="26" FontWeight="Bold" Margin="0,0,10,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="10" Color="Black" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="SoundVibe" Foreground="#FFFFFF" FontSize="18"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <RadioButton x:Name="TabLibrary" GroupName="Menu" IsChecked="True"
                                                 Style="{StaticResource SidebarButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎵" Margin="0,0,15,0" FontSize="16"/>
                                            <TextBlock Text="Library" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="TabEqualizer" GroupName="Menu"
                                                 Style="{StaticResource SidebarButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎚" Margin="0,0,15,0" FontSize="16"/>
                                            <TextBlock Text="Equalizer" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <Button x:Name="BtnAddFolder" Content="📁 Add Folder"
                                            Style="{StaticResource IconButton}"
                                            Margin="20,15,20,10" Height="40" Background="{DynamicResource ThemeGlassBrush}"/>

                                    <TextBlock Text="PLAYLIST" Foreground="#607D8B"
                                               FontSize="10" FontWeight="Bold" Margin="30,15,0,5"/>
                                </StackPanel>

                                <ListBox x:Name="LstSongs" Grid.Row="1" Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         Margin="10,0,10,10">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="Margin" Value="0,2"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#12FFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeGlassBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ContextMenu>
                                                    <ContextMenu Background="{DynamicResource ThemeDarkBgBrush}" Foreground="White" BorderBrush="#30FFFFFF">
                                                        <MenuItem Header="▶ Sıradaki Çal (Play Next)" Click="MenuPlayNext_Click" Background="Transparent"/>
                                                        <MenuItem Header="🎵 Sıraya Ekle (Add to Queue)" Click="MenuAddQueue_Click" Background="Transparent"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="30" Height="30" CornerRadius="6"
                                                        Background="#1C1C1E" HorizontalAlignment="Left"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding CoverImage}" Stretch="Uniform"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                               FontSize="13" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Artist}" FontSize="11"
                                                               Opacity="0.7" Foreground="#B0C4DE"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock x:Name="PlayIndicator" Grid.Column="2"
                                                           Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" FontSize="14"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           Visibility="Collapsed">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="5" Color="Black" ShadowDepth="0" Opacity="0.5"/>
                                                    </TextBlock.Effect>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ılı"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="Visibility" Value="Visible">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard Name="ListEqAnim">
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Duration="0:0:0.8">
                                                                                    <DiscreteStringKeyFrame Value="ılı" KeyTime="0:0:0.0"/>
                                                                                    <DiscreteStringKeyFrame Value="ııı" KeyTime="0:0:0.2"/>
                                                                                    <DiscreteStringKeyFrame Value="lıı" KeyTime="0:0:0.4"/>
                                                                                    <DiscreteStringKeyFrame Value="ııl" KeyTime="0:0:0.6"/>
                                                                                </StringAnimationUsingKeyFrames>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <StopStoryboard BeginStoryboardName="ListEqAnim"/>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="True">
                                                    <Setter TargetName="PlayIndicator" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Grid Grid.Row="2" Margin="20" VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="55" Height="55" CornerRadius="8" Background="#111">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Border CornerRadius="8" ClipToBounds="True">
                                        <Image x:Name="ImgMiniCover" Stretch="Uniform"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                                    <TextBlock x:Name="TxtSidebarNowPlaying" Text="Now Playing" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TxtSidebarArtist" Text="SoundVibe Theme Engine" Foreground="#90A4AE"
                                               FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Foreground="{DynamicResource ThemeAccentLightBrush}" FontSize="9" Margin="0,5,0,0" Opacity="0.7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="ııılılıı"/>
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Duration="0:0:0.8">
                                                                    <DiscreteStringKeyFrame Value="ı ılı" KeyTime="0:0:0.0"/>
                                                                    <DiscreteStringKeyFrame Value="ılı ı" KeyTime="0:0:0.2"/>
                                                                    <DiscreteStringKeyFrame Value="ıı lı" KeyTime="0:0:0.4"/>
                                                                    <DiscreteStringKeyFrame Value="lı ılı" KeyTime="0:0:0.6"/>
                                                                </StringAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="30,20,30,0">
                            <TextBox x:Name="TxtSearch" Width="280" Height="36"
                                     HorizontalAlignment="Left" Style="{StaticResource SearchBoxStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="BtnTheme" Content="🌃 Neon Dream" Width="120" Height="36"
                                        Style="{StaticResource IconButton}" Margin="0,0,15,0"
                                        Background="{DynamicResource ThemeGlassBrush}"/>
                                <Button x:Name="BtnMainToMini" Content="🗗" Width="36" Height="36"
                                        Style="{StaticResource IconButton}" Margin="0,0,5,0"/>
                                <Button x:Name="BtnMinimize" Content="—" Width="36" Height="36"
                                        Style="{StaticResource IconButton}" Margin="0,0,5,0"/>
                                <Button x:Name="BtnClose" Content="✕" Width="36" Height="36"
                                        Style="{StaticResource IconButton}" Foreground="#FF4D4D"/>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="PlayerViewPanel" Grid.Row="1" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="40,0,40,0" ClipToBounds="False">

                                <ComboBox x:Name="CmbVisualizerMode" Width="250" Height="36"
                                          HorizontalAlignment="Right" VerticalAlignment="Top"
                                          Panel.ZIndex="10"
                                          Style="{StaticResource GlassComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource GlassComboBoxItemStyle}"
                                          Margin="0,10,0,0" SelectedIndex="10">
                                    <ComboBoxItem Content="1. Neon Blocks"/>
                                    <ComboBoxItem Content="2. Cyber Wave"/>
                                    <ComboBoxItem Content="3. Classic Oscilloscope"/>
                                    <ComboBoxItem Content="4. Mirror Bars"/>
                                    <ComboBoxItem Content="5. Classic Circular Wave"/>
                                    <ComboBoxItem Content="6. Smoothed Blocks"/>
                                    <ComboBoxItem Content="7. Fracture Bars"/>
                                    <ComboBoxItem Content="8. Liquid Oscilloscope"/>
                                    <ComboBoxItem Content="9. Orbital Galaxy"/>
                                    <ComboBoxItem Content="10. Hyperspace Tunnel"/>
                                    <ComboBoxItem Content="11. Particle Reactor"/>
                                    <ComboBoxItem Content="12. Classic CRT"/>
                                    <ComboBoxItem Content="-- Karaoke Mode --"/>
                                </ComboBox>

                                <Grid VerticalAlignment="Bottom" Height="250" Margin="0,0,0,10">
                                    <Canvas x:Name="VisualizerCanvas" ClipToBounds="False" Height="150" VerticalAlignment="Top"/>

                                    <Rectangle Height="70" VerticalAlignment="Top" Margin="0,150,0,0" Opacity="0.3" RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform>
                                            <ScaleTransform ScaleY="-1"/>
                                        </Rectangle.RenderTransform>
                                        <Rectangle.Fill>
                                            <VisualBrush Visual="{Binding ElementName=VisualizerCanvas}" Stretch="None" AlignmentY="Bottom"/>
                                        </Rectangle.Fill>
                                        <Rectangle.OpacityMask>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                </Grid>

                                <TextBlock x:Name="TxtBigKaraokeLyrics" Foreground="White" FontSize="28"
                                           FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"
                                           Width="700" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>

                            <Grid Grid.Row="1" Margin="40,0,40,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="165" Height="140" HorizontalAlignment="Left">
                                    <Ellipse Width="135" Height="135" Fill="#0D0D0D"
                                             HorizontalAlignment="Right" VerticalAlignment="Center"
                                             Margin="0,0,5,0" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="VinylRotation" Angle="0"/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#222" Offset="0"/>
                                                <GradientStop Color="#555" Offset="0.5"/>
                                                <GradientStop Color="#222" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Stroke>
                                    </Ellipse>

                                    <Border Width="140" Height="140" CornerRadius="12"
                                            Background="#1C1C1E" HorizontalAlignment="Left">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Color="Black" Opacity="0.6"/>
                                        </Border.Effect>
                                        <Border CornerRadius="12" ClipToBounds="True">
                                            <Image x:Name="ImgAlbumCover" Stretch="Uniform"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock x:Name="TxtNowPlayingTitle" Text="SoundVibe"
                                                   Foreground="White" FontSize="32" FontWeight="Bold"
                                                   HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="450"/>
                                    </Grid>
                                    <TextBlock x:Name="TxtNowPlayingArtist" Grid.Row="1"
                                               Text="Waiting for music..." Foreground="{DynamicResource ThemeAccentBrush}"
                                               FontSize="16" Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TxtMetaData" Grid.Row="2"
                                               Text="MP3 • 320 kbps • 44.1 kHz" Foreground="#607D8B"
                                               FontSize="12" Margin="0,15,0,15"/>
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtCurrentTime" Grid.Column="0" Text="0:00"
                                                   Foreground="#B0C4DE" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <Slider x:Name="SldTimeline" Grid.Column="1" Maximum="100" Value="0"
                                                IsMoveToPointEnabled="True"
                                                Style="{StaticResource PremiumSliderStyle}"/>
                                        <TextBlock x:Name="TxtTotalTime" Grid.Column="2" Text="0:00"
                                                   Foreground="#B0C4DE" FontSize="12"
                                                   VerticalAlignment="Center" Margin="15,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="2" Margin="40,0,40,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                                    <Button x:Name="BtnShuffle" Content="🔀" FontSize="18" Width="40" Height="40"
                                            Style="{StaticResource IconButton}" Margin="0,0,15,0"
                                            Foreground="{DynamicResource ThemeAccentBrush}"/>

                                    <Button x:Name="BtnPrev" Content="⏮" FontSize="20" Width="45" Height="45"
                                            Style="{StaticResource IconButton}" Margin="0,0,15,0"/>

                                    <Border Width="56" Height="56" CornerRadius="28" Margin="0,0,15,0" Background="{DynamicResource ThemeSliderGradient}">
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="PlayGlow" BlurRadius="20"
                                                              Color="Black" Opacity="0.5" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <Button x:Name="BtnPlayPause" Content="▶" FontSize="22"
                                                Foreground="White" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand"/>
                                    </Border>

                                    <Button x:Name="BtnNext" Content="⏭" FontSize="20" Width="45" Height="45"
                                            Style="{StaticResource IconButton}" Margin="0,0,15,0"/>

                                    <Button x:Name="BtnRepeat" Content="🔁" FontSize="18" Width="40" Height="40"
                                            Style="{StaticResource IconButton}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="🔊" FontSize="16" Foreground="#B0C4DE"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Slider x:Name="SldVolume" Width="100" Maximum="100" Value="50"
                                            VerticalAlignment="Center" Style="{StaticResource PremiumSliderStyle}"/>
                                    <TextBlock Text="{Binding Value, ElementName=SldVolume, StringFormat={}{0:0}%}"
                                               Foreground="#607D8B" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Width="30"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="3" Margin="40,5,40,25" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{DynamicResource ThemeGlassBrush}" CornerRadius="10"
                                        Margin="0,0,10,0" Padding="15,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🎵" Foreground="#90A4AE" FontSize="14" Margin="0,0,10,0"/>
                                            <TextBlock Text="QUEUE" Foreground="#B0C4DE"
                                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Background="#20FFFFFF" CornerRadius="5"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Padding="8,4">
                                            <TextBlock x:Name="TxtQueueCount" Text="0"
                                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Background="{DynamicResource ThemeGlassBrush}" CornerRadius="10"
                                        Margin="5,0,5,0" Padding="15,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="❝" Foreground="{DynamicResource ThemeAccentBrush}" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="LYRICS" Foreground="#B0C4DE"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtWidgetLyrics" Text="♪ Lirik Bulunamadı ♪"
                                                   Foreground="{DynamicResource ThemeAccentBrush}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="{DynamicResource ThemeGlassBrush}" CornerRadius="10"
                                        Margin="10,0,0,0" Padding="15,0">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="🎚" Foreground="#90A4AE" FontSize="12" Margin="0,0,5,0"/>
                                                <TextBlock Text="EQUALIZER" Foreground="#B0C4DE"
                                                           FontSize="10" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="Custom Preset" Foreground="{DynamicResource ThemeAccentLightBrush}" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" Height="15"
                                                    Margin="0,0,0,8" Opacity="0.5">
                                            <Rectangle Width="2" Height="10" Fill="{DynamicResource ThemeAccentBrush}" Margin="1,0" VerticalAlignment="Bottom"/>
                                            <Rectangle Width="2" Height="15" Fill="{DynamicResource ThemeAccentBrush}" Margin="1,0" VerticalAlignment="Bottom"/>
                                            <Rectangle Width="2" Height="8" Fill="{DynamicResource ThemeAccentBrush}" Margin="1,0" VerticalAlignment="Bottom"/>
                                            <Rectangle Width="2" Height="12" Fill="{DynamicResource ThemeAccentBrush}" Margin="1,0" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="EqViewPanel" Grid.Row="1" Visibility="Collapsed" Margin="40,20,40,40">
                            <Border Background="{DynamicResource ThemeGlassBrush}" BorderBrush="#15FFFFFF" BorderThickness="1"
                                    CornerRadius="20" Padding="40">
                                <StackPanel>
                                    <TextBlock Text="10-Band Studio Equalizer" Foreground="White"
                                               FontWeight="Bold" FontSize="28" Margin="0,0,0,10"/>
                                    <TextBlock Text="Gerçek zamanlı olarak NAudio BiQuad filtresi üzerinden donanım sesini işler."
                                               Foreground="#B0C4DE" FontSize="14" Margin="0,0,0,30"/>
                                    <ComboBox Width="250" HorizontalAlignment="Left"
                                              Style="{StaticResource GlassComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource GlassComboBoxItemStyle}"
                                              Margin="0,0,0,30" SelectedIndex="0">
                                        <ComboBoxItem Content="Flat (Normal)"/>
                                        <ComboBoxItem Content="Bass Boost"/>
                                        <ComboBoxItem Content="Vocal Enhancer"/>
                                        <ComboBoxItem Content="Electronic"/>
                                    </ComboBox>
                                    <Viewbox Stretch="Uniform" Margin="10,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="50"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="60"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="40"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="50"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="50"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="45"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="55"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="60"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="70"/>
                                            <Slider Style="{StaticResource VerticalEQSlider}" Value="65"/>
                                        </StackPanel>
                                    </Viewbox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="MiniUI" Visibility="Collapsed">
                    <Canvas x:Name="MiniVisualizerCanvas" ClipToBounds="True"
                            Opacity="0.15" VerticalAlignment="Bottom" Height="80"/>
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="55" Height="55" CornerRadius="8"
                                Background="#1C1C1E" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.5"/>
                            </Border.Effect>
                            <Border CornerRadius="8" ClipToBounds="True">
                                <Image x:Name="ImgMiniPlayerCover" Stretch="Uniform"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </Border>

                        <Grid Grid.Column="1" Margin="5,15,10,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TxtMiniTitle" Text="SoundVibe Theme Engine"
                                       Foreground="White" FontWeight="Bold" FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TxtMiniArtist" Grid.Row="1" Text="Waiting for music..."
                                       Foreground="{DynamicResource ThemeAccentBrush}" FontSize="11" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <Slider x:Name="SldMiniTimeline" Grid.Row="2" VerticalAlignment="Bottom"
                                    IsMoveToPointEnabled="True"
                                    Maximum="100" Value="0" Style="{StaticResource PremiumSliderStyle}"/>
                        </Grid>

                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Button x:Name="BtnMiniPrev" Content="⏮" FontSize="14" Width="26" Height="26"
                                    Style="{StaticResource IconButton}"/>
                            <Border Width="35" Height="35" CornerRadius="17.5" Margin="8,0" Background="{DynamicResource ThemeMiniGradient}">
                                <Button x:Name="BtnMiniPlayPause" Content="▶" FontSize="14"
                                        Foreground="White" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"/>
                            </Border>
                            <Button x:Name="BtnMiniNext" Content="⏭" FontSize="14" Width="26" Height="26"
                                    Style="{StaticResource IconButton}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Top" Margin="0,8,0,0">
                            <Button x:Name="BtnMiniToMain" Content="🗖" FontSize="12" Width="24" Height="24"
                                    Style="{StaticResource IconButton}" ToolTip="Restore" Margin="0,0,0,5"/>
                            <Button x:Name="BtnMiniClose" Content="✕" FontSize="12" Width="24" Height="24"
                                    Style="{StaticResource IconButton}" Foreground="#FF4D4D"/>
                        </StackPanel>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>